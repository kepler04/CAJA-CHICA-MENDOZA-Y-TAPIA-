# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno — Caja Chica Mendoza y Tapia
# Copia este archivo a ".env" y completa los valores desde Supabase.
# NUNCA subas el archivo .env real al repositorio.
# ─────────────────────────────────────────────────────────────

# Base de datos (Supabase -> Settings -> Database -> Connection string)
# DATABASE_URL: modo "Transaction" (pooler, puerto 6543). Añade ?pgbouncer=true
# DIRECT_URL:   modo "Session"/Direct (puerto 5432), usado por las migraciones.
# Si la contraseña tiene caracteres especiales, codifícalos (ej. "@" -> "%40").
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# Supabase Auth (Settings -> API). Cliente browser + server.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
# Usa una de las dos (la nueva publishable o la clásica anon). Cualquiera sirve.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxx"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# Clave secreta de servidor (Settings -> API -> service_role). SOLO servidor.
# Necesaria para crear usuarios en Supabase Auth desde la app. NO la expongas.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...service_role..."

# Modo demo: "true" permite recorrer la UI sin Supabase (sin login real).
# En producción déjalo en "false" o no lo definas.
NEXT_PUBLIC_DEMO_MODE="false"
